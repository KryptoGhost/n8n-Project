              "type": "array",
              "value": "={{ [] }}"
            },
            {
              "id": "7",
              "name": "validation_status",
              "type": "string",
              "value": "={{ $json.is_duplicate ? \"duplicate\" : (!$json.vendor_exists ? \"unknown_vendor\" : ($json.amount_mismatch ? \"amount_mismatch\" : \"valid\")) }}"
