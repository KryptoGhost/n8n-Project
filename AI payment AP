              "value": "={{ $(\"Validate Purchase Order\").item.json.id ? true : false }}"
            },
            {
              "id": "4",
              "name": "amount_mismatch",
              "type": "boolean",
              "value": "={{ $(\"Validate Purchase Order\").item.json.approved_amount && Math.abs($(\"Validate Purchase Order\").item.json.approved_amount - $json.total_amount) > 0.01 }}"
